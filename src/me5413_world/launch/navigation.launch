<launch>

  <!-- Connect the robot to a keyboard teleop controller -->
  <node name="teleop_twist_keyboard" pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py" output="screen" respawn="true"/>

  <!-- Run the map server -->
  <arg name="map_file" default="$(find me5413_world)/maps/my_map.yaml"/>
  <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_file)" />
  
  <!-- Launch the AMCL Localizer -->
  <include file="$(find jackal_navigation)/launch/include/amcl.launch" />

    <!-- AMCL Misc. -->
      <param name="amcl/odom_model_type" value="diff-corrected"/>

      <param name="amcl/scan_topic" value="/front/filtered_scan"/>
      
      <param name="amcl/laser_max_beams" value="120"/>

    <!-- Tuning AMCL laser - adjusted to listen almost only to positive matches with the map -->
      <!-- laser_z_hit - Weightage for "correct" beams -->
      <!-- laser_z_rand - Random readin tolerance --> 
      <!-- laser_z_short - Tolerance for obstacles -->
      <!-- laser_z_max - Ignore inf length beams -->
      <param name="amcl/laser_z_hit" value="0.97"/>
      <param name="amcl/laser_z_rand" value="0.01"/> 
      <param name="amcl/laser_z_short" value="0.02"/> 
      <param name="amcl/laser_z_max" value="0"/>  

    <!-- Tuning AMCL Motion - Increasing noise and randomness in model for motion 
      - Increasing these reduced drift when stationary
    -->
      <!-- alpha1 - Rotation error from Rotation -->
      <!-- alpha2 - Rotation error from Translation -->
      <!-- alpha3 - Translation error from Translation -->
      <!-- alpha4 - Translation error from Rotation -->
      <param name="amcl/alpha1" value="0.4"/> 
      <param name="amcl/alpha2" value="0.4"/> 
      <param name="amcl/alpha3" value="0.05"/> 
      <param name="amcl/alpha4" value="0.02"/> 

    <!-- Tuning AMCL Trigger - Decreasing distance travelled BEFORE update -->
      <!-- Min distance for update -->
      <!-- Min rotation for update -->
      <param name="amcl/update_min_d" value="0.05"/> 
      <param name="amcl/update_min_a" value="0.05"/> 

    <!-- More... -->
      <param name="amcl/min_particles" value="300"/>



  <!-- Launch Move Base -->
  <include file="$(find jackal_navigation)/launch/include/move_base.launch" />

  <param name="move_base/local_costmap/obstacles_layer/scan/topic" value="/front/scan"/>
  <param name="move_base/local_costmap/obstacles_layer/scan/sensor_frame" value="velodyne"/>
  <param name="move_base/global_costmap/obstacles_layer/scan/topic" value="/front/scan"/>
  <param name="move_base/global_costmap/obstacles_layer/scan/sensor_frame" value="velodyne"/>

  <!-- Launch Rviz with our settings -->
  <node type="rviz" name="rviz" pkg="rviz" args="-d $(find me5413_world)/rviz/navigation.rviz" output="log" respawn="true"/>

  <node ns="me5413_world" pkg="me5413_world" type="goal_publisher_node" name="goal_publisher_node" output="screen" />

</launch>
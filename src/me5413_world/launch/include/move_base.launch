<launch>
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">

    <param name="base_global_planner" type="string" value="navfn/NavfnROS" />
    <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>
    <param name="planner_frequency" value="2.0" />
    <param name="controller_frequency" value="10.0" />
    <param name="conservative_reset_dist" value="3.0" />
    <param name="clearing_rotation_allowed" value="false" />

    <remap from="odom" to="odometry/filtered" />

    <!-- Global costmap: static map + live obstacle detection -->
    <rosparam ns="global_costmap">
      global_frame: map
      robot_base_frame: base_link
      update_frequency: 5.0
      publish_frequency: 2.0
      static_map: true
      transform_tolerance: 0.5

      footprint: [[-0.21, -0.165], [-0.21, 0.165], [0.21, 0.165], [0.21, -0.165]]

      plugins:
        - {name: static_layer, type: "costmap_2d::StaticLayer"}
        - {name: obstacle_layer, type: "costmap_2d::ObstacleLayer"}
        - {name: inflation_layer, type: "costmap_2d::InflationLayer"}

      obstacle_layer:
        observation_sources: scan
        scan: {sensor_frame: tim551, data_type: LaserScan, topic: front/scan,
               marking: true, clearing: false, obstacle_range: 6.0, raytrace_range: 8.0,
               min_obstacle_height: -2.0, max_obstacle_height: 2.0}

      inflation_layer:
        inflation_radius: 0.5
        cost_scaling_factor: 2.5
    </rosparam>

    <!-- Local costmap: rolling window with live obstacles -->
    <rosparam ns="local_costmap">
      global_frame: odom
      robot_base_frame: base_link
      update_frequency: 10.0
      publish_frequency: 5.0
      static_map: false
      rolling_window: true
      width: 6.0
      height: 6.0
      resolution: 0.05
      transform_tolerance: 0.5

      footprint: [[-0.21, -0.165], [-0.21, 0.165], [0.21, 0.165], [0.21, -0.165]]

      plugins:
        - {name: obstacle_layer, type: "costmap_2d::ObstacleLayer"}
        - {name: inflation_layer, type: "costmap_2d::InflationLayer"}

      obstacle_layer:
        observation_sources: scan
        scan: {sensor_frame: tim551, data_type: LaserScan, topic: front/scan,
               marking: true, clearing: true, obstacle_range: 6.0, raytrace_range: 8.0,
               min_obstacle_height: -2.0, max_obstacle_height: 2.0}

      inflation_layer:
        inflation_radius: 0.5
        cost_scaling_factor: 2.5
    </rosparam>

    <!-- DWA local planner -->
    <rosparam file="$(find me5413_world)/config/dwa_local_planner_params.yaml" command="load" />

  </node>
</launch>

<launch>
  <node pkg="amcl" type="amcl" name="amcl" output="screen">
    <param name="use_map_topic" value="false"/>

    <!-- Odometry model -->
    <param name="odom_model_type" value="diff"/>
    <param name="odom_alpha1" value="0.1"/>
    <param name="odom_alpha2" value="0.1"/>
    <param name="odom_alpha3" value="0.1"/>
    <param name="odom_alpha4" value="0.1"/>
    <param name="odom_alpha5" value="0.1"/>
    <param name="odom_frame_id" value="odom"/>
    <param name="base_frame_id" value="base_link"/>
    <param name="global_frame_id" value="map"/>

    <!-- More particles = better localisation in complex environments -->
    <param name="min_particles" value="1000"/>
    <param name="max_particles" value="5000"/>
    <param name="kld_err" value="0.02"/>
    <param name="kld_z" value="0.99"/>

    <!-- Laser model: robust to boxes not in map.
         Few beams so box hits don't dominate. High z_rand since
         many readings will hit objects not in the static map. -->
    <param name="laser_max_beams" value="60"/>
    <param name="laser_min_range" value="0.1"/>
    <param name="laser_max_range" value="25.0"/>
    <param name="laser_model_type" value="likelihood_field"/>
    <param name="laser_z_hit" value="0.5"/>
    <param name="laser_z_short" value="0.05"/>
    <param name="laser_z_max" value="0.05"/>
    <param name="laser_z_rand" value="0.4"/>
    <param name="laser_sigma_hit" value="0.25"/>
    <param name="laser_lambda_short" value="0.1"/>
    <param name="laser_likelihood_max_dist" value="2.0"/>

    <!-- Update more frequently for tighter tracking -->
    <param name="update_min_d" value="0.05"/>
    <param name="update_min_a" value="0.1"/>
    <param name="resample_interval" value="1"/>
    <param name="gui_publish_rate" value="10.0"/>
    <param name="transform_tolerance" value="0.5"/>

    <!-- Recovery: allow adding random poses when lost -->
    <param name="recovery_alpha_slow" value="0.001"/>
    <param name="recovery_alpha_fast" value="0.1"/>

    <!-- Initial pose: robot starts at map (0, 0) with tight uncertainty -->
    <param name="initial_pose_x" value="0.0"/>
    <param name="initial_pose_y" value="0.0"/>
    <param name="initial_pose_a" value="0.0"/>
    <param name="initial_cov_xx" value="0.05"/>
    <param name="initial_cov_yy" value="0.05"/>
    <param name="initial_cov_aa" value="0.01"/>

    <param name="receive_map_topic" value="true"/>
    <param name="first_map_only" value="false"/>

    <remap from="scan" to="front/scan"/>
  </node>
</launch>
